---
import NavMenu from "$lib/components/NavMenu.svelte";
import Sidebar from "$lib/components/Sidebar.svelte";
import Text from "$lib/components/Text.svelte";
import { Button } from "$lib/components/ui/button";
---

<header class="layout-full py-4">
  <nav class="flex min-h-16 w-full items-center">
    <Text as="h1" variant="display" class="flex-1">
      <a href="/">Sojourners <br class="hidden md:inline" /> Church</a>
    </Text>

    <NavMenu class="hidden gap-2 lg:inline-flex"/>

    <Sidebar client:load />
  </nav>
</header>
